{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs-debug",
      "displayName": "Windows VS2026 Debug",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/windows-vs-debug",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/windows-vs-debug"
      }
    },
    {
      "name": "windows-vs-release",
      "displayName": "Windows VS2026 Release",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/windows-vs-release",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/windows-vs-release"
      }
    },
    {
      "name": "ninja-debug",
      "displayName": "Ninja Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/ninja-debug"
      }
    },
    {
      "name": "ninja-release",
      "displayName": "Ninja Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/ninja-release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-windows-debug",
      "configurePreset": "windows-vs-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-windows-release",
      "configurePreset": "windows-vs-release",
      "configuration": "Release"
    },
    {
      "name": "build-ninja-debug",
      "configurePreset": "ninja-debug"
    },
    {
      "name": "build-ninja-release",
      "configurePreset": "ninja-release"
    }
  ],
  "testPresets": [
    {
      "name": "test-windows-debug",
      "configurePreset": "windows-vs-debug",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "test-windows-release",
      "configurePreset": "windows-vs-release",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "test-ninja-debug",
      "configurePreset": "ninja-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "test-ninja-release",
      "configurePreset": "ninja-release",
      "output": { "outputOnFailure": true }
    }
  ]
}